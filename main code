# ---------------------------------
# Pie chart data
# ---------------------------------
def get_pie_data(df, year_value, prod_cols):
    pie_df = (
        df[df["Year"] == year_value][prod_cols]
        .sum(numeric_only=True)
        .reset_index()
    )
    pie_df.columns = ["Type", "Production"]
    total = pie_df["Production"].sum()

    pie_df["pct"] = np.where(total > 0, pie_df["Production"] / total, 0)
    pie_df["pct_label"] = pie_df["pct"].map(lambda x: f"{x:.1%}")
    pie_df["prod_label"] = pie_df["Production"].map(lambda x: f"{int(round(x)):,}")
    pie_df["label_text"] = (
        pie_df["Type"] + "<br>" +
        pie_df["pct_label"] + "<br>(" +
        pie_df["prod_label"] + ")"
    )
    return pie_df, total

# ---------------------------------
# Line chart data
# ---------------------------------
def get_line_data(df, selected_types, mode, year_focus=None, month_focus=None):
    if mode == "within_year":
        temp = df[df["Year"] == year_focus][["Year", "Month"] + selected_types].copy()
        long_df = temp.melt(
            id_vars=["Year", "Month"],
            value_vars=selected_types,
            var_name="Type",
            value_name="Production"
        )
        result = (
            long_df.groupby(["Year", "Month", "Type"], observed=False)["Production"]
            .sum()
            .reset_index()
        )
        return result.sort_values(["Month", "Type"])

    elif mode == "month_across_years":
        temp = df[df["Month"] == month_focus][["Year", "Month"] + selected_types].copy()
        long_df = temp.melt(
            id_vars=["Year", "Month"],
            value_vars=selected_types,
            var_name="Type",
            value_name="Production"
        )
        result = (
            long_df.groupby(["Year", "Month", "Type"], observed=False)["Production"]
            .sum()
            .reset_index()
        )
        return result.sort_values(["Year", "Type"])

    else:
        temp = df[["Year"] + selected_types].copy()
        long_df = temp.melt(
            id_vars=["Year"],
            value_vars=selected_types,
            var_name="Type",
            value_name="Production"
        )
        result = (
            long_df.groupby(["Year", "Type"])["Production"]
            .sum()
            .reset_index()
        )
        return result.sort_values(["Year", "Type"])

