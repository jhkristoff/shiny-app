# ---------------------------------
# Helper function to clean numeric columns
# ---------------------------------
def clean_numeric_series(series):
    series = series.astype(str).str.strip()
    series = series.replace(["", "N/A", "NA", "null", "NULL"], np.nan)
    series = series.str.replace(",", "", regex=False)
    return pd.to_numeric(series, errors="coerce")

# ---------------------------------
# Create unknown column F
# ---------------------------------
def create_unknown_column(df):
    df = df.copy()

    cols_to_clean = ["A", "B", "C", "D", "E", "Production"]
    for col in cols_to_clean:
        df[col] = clean_numeric_series(df[col])

    df["missing_count"] = df[["A", "B", "C", "D", "E"]].isna().sum(axis=1)
    df["known_total"] = df[["A", "B", "C", "D", "E"]].sum(axis=1, skipna=True)

    df["F"] = np.where(
        df["missing_count"] == 0,
        0,
        df["Production"] - df["known_total"]
    )

    df["F"] = df["F"].fillna(0)
    df["F"] = np.where(df["F"] < 0, 0, df["F"])

    df = df.drop(columns=["missing_count", "known_total"])
    return df

# ---------------------------------
# Load data
# ---------------------------------
@st.cache_data
def load_data():
    df = pd.read_csv("national_actual_1.csv")

    required_cols = [
        "Month", "Year", "Date", "Industry_members",
        "Production", "A", "B", "C", "D", "E"
    ]

    missing = [col for col in required_cols if col not in df.columns]
    if missing:
        raise ValueError(f"Missing required columns in CSV: {missing}")

    pilot_df = df[required_cols].copy()
    pilot_df = create_unknown_column(pilot_df)

    app_df = pilot_df.rename(columns={
        "A": "Still Wine ≤ 16% ABV",
        "B": "Still Wine > 16% ABV",
        "C": "Sparkling Wine",
        "D": "Artificially Carbonated Wine",
        "E": "Hard Cider",
        "F": "Unknown"
    })

    month_levels = [
        "January", "February", "March", "April", "May", "June",
        "July", "August", "September", "October", "November", "December"
    ]

    app_df["Month"] = pd.Categorical(
        app_df["Month"],
        categories=month_levels,
        ordered=True
    )

    app_df["Year"] = pd.to_numeric(app_df["Year"], errors="coerce")

    production_cols = [
        "Still Wine ≤ 16% ABV",
        "Still Wine > 16% ABV",
        "Sparkling Wine",
        "Artificially Carbonated Wine",
        "Hard Cider",
        "Unknown"
    ]

    return app_df, production_cols, month_levels

app_df, production_cols, month_levels = load_data()

