server <- function(input, output) {
  
  output$selectedTypesText <- renderText({
    paste(input$type1, "vs.", input$type2)
  })
  
  # -------------------------------
  # PIE CHART DATA
  # -------------------------------
  pie_data <- reactive({
    app_df %>%
      filter(Year == input$year_select) %>%
      summarise(across(all_of(production_cols), ~ sum(.x, na.rm = TRUE))) %>%
      pivot_longer(
        everything(),
        names_to = "Type",
        values_to = "Production"
      ) %>%
      mutate(
        pct = Production / sum(Production),
        pct_label = percent(pct, accuracy = 0.1),
        prod_label = label_number(big.mark = ",")(Production),
        label_text = paste0(Type, "\n", pct_label, "\n(", prod_label, ")")
      )
  })
  
  output$pieChart <- renderPlot({
    
    pie_colors <- c(
      "Still Wine ≤ 16% ABV" = "#5c0f1b",
      "Still Wine > 16% ABV" = "#8b1e2d",
      "Sparkling Wine" = "#b23a48",
      "Artificially Carbonated Wine" = "#c95c6d",
      "Hard Cider" = "#df8f9a",
      "Unknown" = "#e8c7cc"
    )
    
    total_prod <- sum(pie_data()$Production, na.rm = TRUE)
    
    ggplot(pie_data(), aes(x = 2, y = Production, fill = Type)) +
      geom_col(color = "white", linewidth = 1) +
      coord_polar(theta = "y") +
      xlim(0.5, 2.6) +
      geom_text(
        aes(label = ifelse(pct >= 0.04, label_text, "")),
        position = position_stack(vjust = 0.5),
        size = 5.5,
        lineheight = 0.95,
        color = "white"
      ) +
      scale_fill_manual(values = pie_colors) +
      labs(
        title = paste("Production Share -", input$year_select),
        subtitle = paste("Total Annual Production:", comma(total_prod)),
        fill = "Wine Type"
      ) +
      theme_void(base_size = 15) +
      theme(
        plot.title = element_text(size = 22, face = "bold", color = "#5c0f1b"),
        plot.subtitle = element_text(size = 15, color = "#6b1f2a"),
        legend.title = element_text(size = 15, face = "bold"),
        legend.text = element_text(size = 13),
        legend.position = "right"
      )
  })
  
  # -------------------------------
  # LINE GRAPH DATA
  # -------------------------------
  line_data <- reactive({
    
    selected <- unique(c(input$type1, input$type2))
    
    if (input$view_mode == "within_year") {
      
      app_df %>%
        filter(Year == input$year_focus) %>%
        select(Year, Month, all_of(selected)) %>%
        pivot_longer(
          cols = all_of(selected),
          names_to = "Type",
          values_to = "Production"
        ) %>%
        group_by(Year, Month, Type) %>%
        summarise(
          Production = sum(Production, na.rm = TRUE),
          .groups = "drop"
        )
      
    } else if (input$view_mode == "month_across_years") {
      
      app_df %>%
        filter(Month == input$month_focus) %>%
        select(Year, Month, all_of(selected)) %>%
        pivot_longer(
          cols = all_of(selected),
          names_to = "Type",
          values_to = "Production"
        ) %>%
        group_by(Year, Month, Type) %>%
        summarise(
          Production = sum(Production, na.rm = TRUE),
          .groups = "drop"
        )
      
    } else {
      
      app_df %>%
        select(Year, all_of(selected)) %>%
        pivot_longer(
          cols = all_of(selected),
          names_to = "Type",
          values_to = "Production"
        ) %>%
        group_by(Year, Type) %>%
        summarise(
          Production = sum(Production, na.rm = TRUE),
          .groups = "drop"
        )
    }
  })
  
  output$lineChart <- renderPlot({
    
    line_colors <- c("#7f1127", "#d35d6e")
names(line_colors) <- c(input$type1, input$type2)

scale_color_manual(values = line_colors)
    names(line_colors) <- c(input$type1, input$type2)
    
    base_plot <- ggplot(
      line_data(),
      aes(
        y = Production,
        color = Type,
        group = Type
      )
    ) +
      geom_line(linewidth = 1.5) +
      geom_point(size = 3) +
      scale_color_manual(values = line_colors) +
      scale_y_continuous(
        labels = label_number(scale = 1e-6, suffix = "M"),
        expand = expansion(mult = c(0.05, 0.1))
      ) +
      labs(
        color = "Selected Wine Types",
        y = "Production (Millions)"
      ) +
      guides(
        color = guide_legend(
          override.aes = list(linewidth = 2.5, size = 4)
        )
      ) +
      theme_minimal(base_size = 15) +
      theme(
        plot.title = element_text(size = 22, face = "bold", color = "#5c0f1b"),
        plot.subtitle = element_text(size = 15, color = "#6b1f2a"),
        axis.title = element_text(size = 15, face = "bold"),
        axis.text = element_text(size = 12, color = "#3b1f24"),
        axis.text.x = element_text(angle = 45, hjust = 1),
        legend.title = element_text(size = 15, face = "bold"),
        legend.text = element_text(size = 13),
        legend.background = element_rect(fill = "#fff5f6", color = "#cfa5ad"),
        legend.box.background = element_rect(fill = "#fff5f6", color = "#cfa5ad"),
        legend.position = "bottom",
        panel.grid.minor = element_blank(),
        panel.grid.major.x = element_blank()
      )
    
    if (input$view_mode == "within_year") {
      
      base_plot +
        aes(x = Month) +
        labs(
          title = paste("Monthly Production in", input$year_focus),
          subtitle = paste("Comparing", input$type1, "and", input$type2, "within one year"),
          x = "Month"
        )
      
    } else if (input$view_mode == "month_across_years") {
      
      base_plot +
        aes(x = Year) +
        labs(
          title = paste(input$month_focus, "Production Across Years"),
          subtitle = paste("Comparing", input$type1, "and", input$type2, "for", input$month_focus, "over time"),
          x = "Year"
        ) +
        scale_x_continuous(breaks = sort(unique(app_df$Year)))
      
    } else {
      
      base_plot +
        aes(x = Year) +
        labs(
          title = "Annual Total Production by Year",
          subtitle = paste("Comparing annual totals for", input$type1, "and", input$type2),
          x = "Year"
        ) +
        scale_x_continuous(breaks = sort(unique(app_df$Year)))
    }
  })
}

# ---------------------------------
# RUN APP
# ---------------------------------
shinyApp(ui = ui, server = server)
