library(dplyr)
create_unknown_column <- function(df) {
  df %>%
    mutate(
      # Clean A:E first so numeric values are preserved
      across(A:E, ~ {
        x <- trimws(as.character(.))
        x[x %in% c("", "N/A", "NA", "null", "NULL")] <- NA
        x <- gsub(",", "", x)
        as.numeric(x)
      }),
      
      # Clean Production too, in case it is stored as text
      Production = {
        x <- trimws(as.character(Production))
        x[x %in% c("", "N/A", "NA", "null", "NULL")] <- NA
        x <- gsub(",", "", x)
        as.numeric(x)
      },
      
      # Count how many of A:E are missing
      missing_count = rowSums(is.na(across(A:E))),
      
      # Sum only known values from A:E
      known_total = rowSums(across(A:E), na.rm = TRUE),
      
      # If all five values are present, F = 0
      # Otherwise, F = Production - known total
      F = ifelse(
        missing_count == 0,
        0,
        Production - known_total
      ),
      
      # Prevent negative values in F
      F = ifelse(is.na(F) | F < 0, 0, F)
    ) %>%
    select(-missing_count, -known_total)
}

